# Production secrets for docker-compose.prod.yml
# Copy to .env (which Compose auto-loads) and fill in — NEVER commit the real .env.
#
#   cp .env.prod.example .env
#   $EDITOR .env
#
# ============================================================================
# Domains (must match your Caddyfile + Authelia config)
# ============================================================================
CHRONICLE_HOST=chronicle.example.com
AUTH_HOST=auth.example.com

# ============================================================================
# Nextcloud hybrid storage (STORAGE_PROVIDER=hybrid)
# ============================================================================
# NC_PASS must be a Nextcloud *App Password*
# (Settings -> Security -> Devices & sessions -> Create new app password),
# NOT your account login password.
NEXTCLOUD_URL=https://cloud.example.com
NC_USER=your-nextcloud-username
NC_PASS=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx
NC_DIR=Chronicle_Storage

# ============================================================================
# AI (server-side, optional). Set only the providers you actually use;
# any provider without a key is simply hidden in the app's Settings.
# ============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# Purist mode: AI_UI=off (or false/0/no) removes every AI surface from the
# app AND makes the server refuse AI API calls (403). Leave unset/on to keep
# AI available.
# AI_UI=off
