# Production secrets for docker-compose.prod.yml
# Copy to .env (which Compose auto-loads) and fill in — NEVER commit the real .env.
#
#   cp .env.prod.example .env
#   $EDITOR .env
#
# ============================================================================
# Domains (must match your Caddyfile + Authelia config)
# ============================================================================
CHRONICLE_HOST=chronicle.example.com
AUTH_HOST=auth.example.com

# ============================================================================
# Async Nextcloud recovery replica (SQLite remains authoritative)
# ============================================================================
# docker-compose.prod.yml defaults this value to nextcloud. Configure exactly
# one of nextcloud, s3, or none; never select two remote providers together.
STORAGE_REPLICA=nextcloud
# NC_PASS must be a Nextcloud *App Password*
# (Settings -> Security -> Devices & sessions -> Create new app password),
# NOT your account login password.
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_ALLOW_INSECURE_HTTP=false
NC_USER=your-nextcloud-username
NC_PASS=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx
NC_DIR=Chronicle_Storage

# Optional outbox tuning (defaults shown):
# STORAGE_RETRY_INTERVAL_MS=30000
# STORAGE_MAX_ATTEMPTS=10

# To use S3 instead, set STORAGE_REPLICA=s3 above and provide the variables
# below. The Compose file passes both providers' variables, but Chronicle only
# initializes the selected replica. Works with AWS S3,
# MinIO, Cloudflare R2, Backblaze B2, and other Signature V4 services.
# S3_BUCKET=chronicle-backup
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.example.com  # omit for AWS
# S3_PREFIX=chronicle
# S3_FORCE_PATH_STYLE=false
# S3_ALLOW_INSECURE_HTTP=false
# S3_SERVER_SIDE_ENCRYPTION=AES256    # optional: AES256 | aws:kms
# S3_KMS_KEY_ID=                     # required with aws:kms

# S3 credentials use the standard AWS SDK chain. Static container credentials:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=                 # only for temporary credentials

# Deprecated upgrade mapping only (do not use for new deployments):
# STORAGE_PROVIDER=sqlite -> STORAGE_REPLICA=none
# STORAGE_PROVIDER=hybrid -> STORAGE_REPLICA=nextcloud

# ============================================================================
# AI (server-side, optional). Set only the providers you actually use;
# any provider without a key is simply hidden in the app's Settings.
# ============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# Purist mode: AI_UI=off (or false/0/no) removes every AI surface from the
# app AND makes the server refuse AI API calls (403). Leave unset/on to keep
# AI available.
# AI_UI=off
