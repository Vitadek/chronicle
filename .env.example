# ---- Core ----
PORT=3000
HOST=0.0.0.0
DATA_DIR=./data
NODE_ENV=development

# ============================================================================
# AUTH MODE
# ============================================================================
# Pick exactly one of: none, token, forward, oidc
AUTH_MODE=none

# Production fails closed when AUTH_MODE=none binds beyond loopback. Set this
# explicit opt-in only for a trusted/private network (or use token/forward/oidc).
# ALLOW_INSECURE_NO_AUTH=true

# ---- Mode: token -----------------------------------------------------------
# Every client sends this as `Authorization: Bearer <token>`.
# AUTH_TOKEN=

# ---- Mode: forward ---------------------------------------------------------
# Trust identity headers from an upstream reverse proxy doing forward auth
# (Traefik/Caddy/Nginx + Authelia/Authentik/oauth2-proxy/etc).
#
# Defaults match Authelia and Caddy. For Authentik, override to:
#   AUTH_FORWARD_HEADER_USER=X-Authentik-Username
#   AUTH_FORWARD_HEADER_EMAIL=X-Authentik-Email
#   AUTH_FORWARD_HEADER_NAME=X-Authentik-Name
#   AUTH_FORWARD_HEADER_GROUPS=X-Authentik-Groups
# For oauth2-proxy:
#   AUTH_FORWARD_HEADER_USER=X-Forwarded-User
#   AUTH_FORWARD_HEADER_EMAIL=X-Forwarded-Email
# AUTH_FORWARD_HEADER_USER=Remote-User
# AUTH_FORWARD_HEADER_EMAIL=Remote-Email
# AUTH_FORWARD_HEADER_NAME=Remote-Name
# AUTH_FORWARD_HEADER_GROUPS=Remote-Groups

# Which immediate TCP peers we'll accept forward-auth headers from. Header
# values from other peers are IGNORED. Use named presets (loopback, linklocal,
# uniquelocal) or explicit CIDRs. Default covers loopback + RFC1918 + ULA,
# fine for most Docker / single-host setups; tighten if your proxy is on a
# specific IP.
# AUTH_FORWARD_TRUSTED_PROXIES=loopback,linklocal,uniquelocal

# Optional belt-and-braces: require the proxy to also send a shared secret.
# AUTH_FORWARD_SECRET_HEADER=X-Forward-Auth-Secret
# AUTH_FORWARD_SECRET=

# ---- Mode: oidc ------------------------------------------------------------
# Standard OIDC with discovery. Tested examples:
#
#   Keycloak:
#     AUTH_OIDC_ISSUER_URL=https://kc.example.com/realms/myrealm
#
#   Authentik:
#     AUTH_OIDC_ISSUER_URL=https://auth.example.com/application/o/chronicle/
#
#   Authelia (with its OIDC provider enabled):
#     AUTH_OIDC_ISSUER_URL=https://auth.example.com
#
#   Google:
#     AUTH_OIDC_ISSUER_URL=https://accounts.google.com
#
# AUTH_OIDC_ISSUER_URL=
# AUTH_OIDC_CLIENT_ID=
# AUTH_OIDC_CLIENT_SECRET=
# AUTH_OIDC_REDIRECT_URI=https://chronicle.example.com/api/auth/oidc/callback
# AUTH_OIDC_SCOPES=openid profile email
# AUTH_OIDC_POST_LOGOUT_REDIRECT_URI=
# AUTH_OIDC_TOKEN_AUTH_METHOD=auto    # auto | none | client_secret_basic | client_secret_post

# ============================================================================
# STORAGE & REDUNDANCY
# ============================================================================
# SQLite is always the authoritative live store. Pick exactly one asynchronous
# recovery replica: none (default), nextcloud, or s3. Remote outages never enter
# the normal read path; writes wait in a durable, retrying outbox.
STORAGE_REPLICA=none
# STORAGE_RETRY_INTERVAL_MS=30000
# STORAGE_MAX_ATTEMPTS=10

# Deprecated upgrade compatibility only:
#   STORAGE_PROVIDER=sqlite maps to STORAGE_REPLICA=none
#   STORAGE_PROVIDER=hybrid maps to STORAGE_REPLICA=nextcloud
# Do not set STORAGE_PROVIDER in a new deployment.

# ---- Nextcloud App Password (Required for STORAGE_REPLICA=nextcloud) --------
# Use an "App Password" from Nextcloud Settings -> Security, not your login pass.
# The base URL is NEXTCLOUD_URL (shared with the optional OAuth identity flow).
# NEXTCLOUD_URL=https://cloud.example.com
# NEXTCLOUD_ALLOW_INSECURE_HTTP=false
# NC_USER=your_username
# NC_PASS=your_long_app_password
# NC_DIR=Chronicle_Storage

# ---- Generic S3 (Required for STORAGE_REPLICA=s3) ---------------------------
# Works with AWS S3 and Signature V4-compatible services such as MinIO,
# Cloudflare R2, and Backblaze B2. The bucket must already exist.
# S3_BUCKET=chronicle-backup
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.example.com  # omit for AWS
# S3_PREFIX=chronicle
# S3_FORCE_PATH_STYLE=false           # commonly true for MinIO
# S3_ALLOW_INSECURE_HTTP=false        # trusted LAN only; HTTPS is enforced otherwise

# Optional provider-side encryption. For KMS, both values are required.
# S3_SERVER_SIDE_ENCRYPTION=AES256    # AES256 | aws:kms
# S3_KMS_KEY_ID=

# Credentials come from the AWS SDK's standard Node credential chain. Static
# keys are the simplest container option; temporary credentials also need the
# session token. AWS profiles, web identity, and ECS/EC2 roles are supported.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=
# AWS_SHARED_CREDENTIALS_FILE=
# AWS_WEB_IDENTITY_TOKEN_FILE=
# AWS_ROLE_ARN=

# ============================================================================
# NEXTCLOUD OAuth Identity (Optional)
# ============================================================================
# Independent of storage replication. Uses OAuth only to link user accounts.
# NEXTCLOUD_URL=https://cloud.example.com
# NEXTCLOUD_CLIENT_ID=
# NEXTCLOUD_CLIENT_SECRET=
# NEXTCLOUD_REDIRECT_URI=https://chronicle.example.com/api/auth/nextcloud/callback
# The legacy NEXTCLOUD_MIRROR write path is removed. Do not set it or
# NEXTCLOUD_MIRROR_ROOT; true/nonempty values are startup errors. Select
# STORAGE_REPLICA=nextcloud with NC_USER and NC_PASS instead.

# ---- AI (optional) ---------------------------------------------------------
# Keys live on the server, never the browser. Users pick a provider + model
# from Settings, and Chronicle attaches the matching key when forwarding.
#
# Set any subset — only providers with a key configured are offered in the UI.
# At boot, Chronicle probes each configured key against the provider's API and
# reports OK/INVALID/ERROR in the logs. Results are also exposed via
# /api/ai/config so the Settings panel can warn about a rejected key.
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# Default text model when the client doesn't pick one.
# AI_MODEL=gpt-4o

# OpenAI TTS (used by /ai_listen). No equivalent for the other providers.
# AUDIO_MODEL=gpt-4o-mini-tts
# AUDIO_VOICE=alloy

# Hide ALL AI features (settings panels, toggles, #!/ai_* slash commands,
# selection bubble menu) for a purely manual writing tool. The server also
# refuses AI API calls (403) while this is set, so no provider key can be
# spent by a stale tab or scripted request. Accepts off/false/0/no.
# AI_UI=off

# ---- Grammar (optional LanguageTool sidecar) --------------------------------
# Point at a LanguageTool server (the repo compose files ship one) to enable
# grammar checking. GRAMMAR_AI_MODEL is the model used for AI-assisted
# grammar suggestions when an AI provider is configured.
# LANGUAGETOOL_URL=http://languagetool:8010
# LANGUAGETOOL_LANG=en-US
# GRAMMAR_AI_MODEL=gemini-2.5-flash

# === OIDC / Authelia stack (docker-compose.oidc.yml) ===
# Hostnames your DNS points at the host (AUTH_HOST should be a subdomain of CHRONICLE_HOST).
CHRONICLE_HOST=chronicle.example.com
AUTH_HOST=auth.chronicle.example.com
# OIDC client; must match the Authelia client. Plaintext secret here, its pbkdf2
# hash in authelia-oidc/oidc_client_secret_hash (authelia crypto hash generate pbkdf2).
AUTH_OIDC_CLIENT_ID=chronicle
AUTH_OIDC_CLIENT_SECRET=change-me
# 1 (or omit) on prod with real certs; 0 only for a self-signed testbed.
NODE_TLS_REJECT_UNAUTHORIZED=1
# Authelia secrets — generate strong random values for prod.
AUTHELIA_SESSION_SECRET=change-me
AUTHELIA_STORAGE_ENCRYPTION_KEY=change-me
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=change-me
AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET=change-me
