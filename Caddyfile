# --- LOCAL DEVELOPMENT / TESTING ---
chronicle.localhost {
    forward_auth authelia:9091 {
        uri /api/verify?rd=https://auth.chronicle.localhost/
        copy_headers Remote-User Remote-Email Remote-Groups
    }
    reverse_proxy chronicle:3000
    tls internal
}

auth.chronicle.localhost {
    reverse_proxy authelia:9091
    tls internal
}

# Catch-all for http -> https redirect
http://chronicle.localhost, http://auth.chronicle.localhost {
    redir https://{host}{uri}
}
